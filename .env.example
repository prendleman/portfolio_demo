# Copy to ".env" in this folder and replace placeholders. ".env" is gitignored — never commit secrets.
#   copy .env.example .env
#
# Scripts that auto-load .env (if python-dotenv is installed): see README "Environment file".

# --- Databricks — Jobs API (scripts/databricks_deploy_demo_job.py) ---
DATABRICKS_HOST=https://adb-0000000000000000.0.azuredatabricks.net
DATABRICKS_TOKEN=dapixxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: use profile from ~/.databrickscfg instead of token
# DATABRICKS_CONFIG_PROFILE=DEFAULT

# --- Databricks — Repos API (scripts/databricks_create_git_repo.py) ---
# GIT_REPO_URL=https://github.com/your-org/portfolio-core-spaces-demo.git
# GIT_REPO_PROVIDER=gitHub
# DATABRICKS_REPO_PATH=/Repos/you@company.com/portfolio-core-spaces-demo
#
# Register Git credentials once if clone fails (Git PAT — not Databricks PAT):
# GIT_CREDENTIAL_PROVIDER=gitHub
# GIT_PERSONAL_ACCESS_TOKEN=
# GIT_EMAIL=you@company.com
# GIT_USERNAME=

# Notebook workspace paths — pick ONE style:
# (A) Full paths (explicit):
NOTEBOOK_TRAIN_PATH=/Repos/you@company.com/portfolio-core-spaces-demo/databricks/02_train_renewal_model/train_mlflow
NOTEBOOK_SCORE_PATH=/Repos/you@company.com/portfolio-core-spaces-demo/databricks/03_score_batch/score_gold
# (B) Single repo root under Repos / Workspace Git folders (script appends defaults below):
# NOTEBOOK_TRAIN_PATH=
# NOTEBOOK_SCORE_PATH=
# DATABRICKS_REPO_WORKSPACE_ROOT=/Repos/you@company.com/portfolio-core-spaces-demo
# Optional suffix overrides (defaults match Asset Bundle paths):
# NOTEBOOK_TRAIN_RELATIVE=databricks/02_train_renewal_model/train_mlflow
# NOTEBOOK_SCORE_RELATIVE=databricks/03_score_batch/score_gold
# (C) Resolve root via Repos API — substring of Git remote URL or of workspace path (requires PAT/profile):
# DATABRICKS_REPO_REMOTE_MATCH=portfolio-core-spaces-demo

DATABRICKS_SPARK_VERSION=15.4.x-scala2.12
DATABRICKS_NODE_TYPE_ID=Standard_DS3_v2
DATABRICKS_NUM_WORKERS=1
DATABRICKS_JOB_NAME="[demo] Train renewal then score gold (API)"

# Serverless-only workspaces: omit classic clusters (see scripts/databricks_deploy_demo_job.py).
# DATABRICKS_USE_SERVERLESS=1
# DATABRICKS_SERVERLESS_ENVIRONMENT_KEY=demo_shared_env
# DATABRICKS_SERVERLESS_ENV_VERSION=5
# DATABRICKS_SERVERLESS_ENV_VERSION_DEFAULT=5
# DATABRICKS_SERVERLESS_DEPENDENCIES=
#   pandas>=2

# After first successful create, uncomment for `python scripts/databricks_deploy_demo_job.py --reset`
# DEMO_JOB_ID=123456789012345

# Optional Quartz schedule (create/reset applies). Pause until ready:
# DATABRICKS_JOB_SCHEDULE_QUARTZ=0 0 14 * * ?
# DATABRICKS_JOB_SCHEDULE_TIMEZONE=America/New_York
# DATABRICKS_JOB_SCHEDULE_PAUSED=1

# Optional: copy scored CSV into Workspace after score task:
# DATABRICKS_GOLD_CSV_WORKSPACE_EXPORT=/Workspace/Users/you@company.com/gold_renewal_scores.csv

# --- Databricks — Asset Bundles CLI (optional; matches bundle template variable) ---
WORKSPACE_HOST=https://adb-0000000000000000.0.azuredatabricks.net

# --- Local pipeline (scripts/run_local_pipeline.py) ---
PORTFOLIO_USE_MLFLOW=0
# Override default file store when needed (Windows example — use your repo path)
# MLFLOW_TRACKING_URI=file:///C:/path/to/portfolio-core-spaces-demo/mlruns
#
# Optional: MLflow / Unity Catalog Model Registry (Databricks only — leave unset locally / file store).
# When set, train_and_register passes registered_model_name into mlflow.sklearn.log_model.
# REGISTER_MODEL_NAME=main.demo.renewal_propensity_classifier
# MLFLOW_REGISTER_MODEL_NAME=main.demo.renewal_propensity_classifier

# --- Power BI — Copilot teaser URL (scripts/gen_pbip_report_pages.py) ---
COPILOT_STUDIO_PUBLISH_URL=https://copilotstudio.microsoft.com/

# --- Streamlit Renewal Lens / tooling (optional) ---
# GOLD_PARQUET_PATH=C:\path\to\portfolio-core-spaces-demo\data\gold\gold_renewal_scores.parquet
# On Databricks App / cluster: UC / Hive gold table (example three-level name).
# GOLD_TABLE=main.demo.gold_renewal_scores
# GOLD_SQL=SELECT * FROM main.demo.gold_renewal_scores LIMIT 500000
# Local Spark testing only (otherwise Parquet path is used):
# PORTFOLIO_ALLOW_SPARK_GOLD=0
# If GOLD_TABLE is in .env but you still see Parquet only: export vars before `streamlit run`, or set PORTFOLIO_ALLOW_SPARK_GOLD=1 when testing Spark locally.

# --- GitHub API (optional — scripts/push_github_repo_metadata.py when `gh` CLI is unavailable) ---
# GH_TOKEN=ghp_xxxxxxxx   # classic PAT: repo scope; fine-grained: Metadata + Administration for topics

# --- Power BI Desktop — GOLD_RENEWAL_CSV_ABSOLUTE_PATH feeds scripts/update_pbip_gold_csv_path.py + semantic model ---
# GOLD_RENEWAL_CSV_ABSOLUTE_PATH=C:\path\to\portfolio-core-spaces-demo\data\gold\gold_renewal_scores.csv
