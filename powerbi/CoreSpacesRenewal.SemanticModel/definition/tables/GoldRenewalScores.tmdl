		summarizeBy: none
		sourceColumn: bedrooms

	column renewed
		dataType: int64
		formatString: 0
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0016
		summarizeBy: average
		sourceColumn: renewed

	column synthetic_signal_z
		dataType: decimal
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0017
		summarizeBy: average
		sourceColumn: synthetic_signal_z

	column dataset_version_id
