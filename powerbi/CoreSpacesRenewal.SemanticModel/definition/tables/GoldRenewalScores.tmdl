		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0022
		summarizeBy: average
		sourceColumn: renewal_probability_ml

	column predicted_renewed_flag
		dataType: int64
		formatString: 0
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0023
		summarizeBy: none
