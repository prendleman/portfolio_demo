	column mlflow_run_id
		dataType: string
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0026
		summarizeBy: none
		sourceColumn: mlflow_run_id

	column model_name
		dataType: string
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0027
		summarizeBy: none
		sourceColumn: model_name

	column scored_at
		dataType: string
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0028
		summarizeBy: none
		sourceColumn: scored_at

	partition GoldRenewalScores-csv = m
		mode: import
		source =
				let
				    Source =
				        Csv.Document(
				            File.Contents(#"GoldRenewalCsvPath"),
				            [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]
				        ),
				    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars = true]),
				    #"Changed Type" =
				        Table.TransformColumnTypes(#"Promoted Headers", {
				            {"tenure_months", Int64.Type},
				            {"monthly_rent", type number},
				            {"market_rent_proxy", type number},
				            {"rent_to_market_ratio", type number},
				            {"late_payment_count_12m", Int64.Type},
				            {"work_order_count_12m", Int64.Type},
				            {"prior_renewal_count", Int64.Type},
				            {"bedrooms", Int64.Type},
				            {"renewed", Int64.Type},
				            {"synthetic_signal_z", type number},
				            {"is_long_tenure", Int64.Type},
				            {"high_service_load", Int64.Type},
				            {"ecosystem_segment", type text},
				            {"brand_line", type text},
				            {"flagship_style", type text},
				            {"metro_cluster", type text},
				            {"property_name", type text},
				            {"renewal_probability_ml", type number},
				            {"predicted_renewed_flag", Int64.Type},
				            {"risk_score", type number}
				        })
				in
				    #"Changed Type"

	annotation PBI_ResultType = Table
