		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0010
		summarizeBy: average
		sourceColumn: market_rent_proxy

	column rent_to_market_ratio
		dataType: decimal
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0011
		summarizeBy: average
		sourceColumn: rent_to_market_ratio

	column late_payment_count_12m
		dataType: int64
		formatString: 0
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0012
		summarizeBy: sum
		sourceColumn: late_payment_count_12m

	column work_order_count_12m
		dataType: int64
		formatString: 0
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0013
		summarizeBy: sum
		sourceColumn: work_order_count_12m

	column prior_renewal_count
		dataType: int64
