/// Gold-layer lease scores produced by the renewal batch job (exported CSV / optional Delta mirror).
/// Grain: one scored lease row (synthetic demo); CSV path from GoldRenewalCsvPath parameter.
table GoldRenewalScores
	lineageTag: 8eefc201-9265-4665-8412-afc4feed0005

	measure 'Renewal Actual Rate %' = AVERAGE(GoldRenewalScores[renewed])
		formatString: 0.0%
		lineageTag: 922f12ab-cccc-dddd-eeee-101010101010

	measure 'Avg Predicted Renewal Prob' = AVERAGE(GoldRenewalScores[renewal_probability_ml])
		formatString: 0.00
		lineageTag: 922f12ab-cccc-dddd-eeee-101010101011

	measure 'Gold Lease Rows' = COUNTROWS(GoldRenewalScores)
		formatString: #,##0
		lineageTag: 922f12ab-cccc-dddd-eeee-101010101012

	measure 'Avg Monthly Rent $' = AVERAGE(GoldRenewalScores[monthly_rent])
		formatString: #,##0
		lineageTag: 922f12ab-cccc-dddd-eeee-101010101013

	measure 'Median Monthly Rent $' = MEDIAN(GoldRenewalScores[monthly_rent])
		formatString: #,##0
		lineageTag: 922f12ab-cccc-dddd-eeee-101010101014

	measure 'Distinct Dataset Versions' = DISTINCTCOUNT(GoldRenewalScores[dataset_version_id])
		formatString: 0
		lineageTag: 922f12ab-cccc-dddd-eeee-101010101016

	measure 'Avg Risk Score' = AVERAGE(GoldRenewalScores[risk_score])
		formatString: 0.000
		lineageTag: 922f12ab-cccc-dddd-eeee-101010101017

	column lease_id
		dataType: string
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0001
		summarizeBy: none
		sourceColumn: lease_id

	column unit_id
		dataType: string
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0002
		summarizeBy: none
		sourceColumn: unit_id

	column property_id
		dataType: string
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0003
		summarizeBy: none
		sourceColumn: property_id

	column metro
		dataType: string
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0004
		summarizeBy: none
		sourceColumn: metro

	column lease_start_date
		dataType: string
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0005
		summarizeBy: none
		sourceColumn: lease_start_date

	column leased_month
		dataType: string
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0006
		summarizeBy: none
		sourceColumn: leased_month

	column as_of_date
		dataType: string
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0007
		summarizeBy: none
		sourceColumn: as_of_date

	column tenure_months
		dataType: int64
		formatString: 0
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0008
		summarizeBy: average
		sourceColumn: tenure_months

	column monthly_rent
		dataType: decimal
		lineageTag: 10000001-aaaa-bbbb-cccc-ddddeeee0009
		summarizeBy: average
		sourceColumn: monthly_rent

	column market_rent_proxy
